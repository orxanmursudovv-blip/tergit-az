# Server
PORT=5000
NODE_ENV=development

# Sayt ünvanı (sitemap.xml, robots.txt və SEO canonical linklər üçün)
# Development zamanı: http://localhost:5173   |   Production-da: https://tergit.az
SITE_URL=http://localhost:5173

# CORS — yalnız bu domeyndən sorğulara icazə verilir
# Development zamanı: http://localhost:5173   |   Production-da: https://tergit.az
ALLOWED_ORIGIN=http://localhost:5173

# JWT
# Production-da MÜTLƏQ uzun, təsadüfi bir sətirlə əvəz edin (məs: openssl rand -hex 32)
JWT_SECRET=dev-only-secret-please-change

# Admin girişi
ADMIN_USERNAME=admin
# Aşağıdakılardan yalnız birini istifadə edin:
# 1) Sadə mətn şifrə (yalnız development üçün, server başlayanda avtomatik hash-lənir)
ADMIN_PASSWORD=azadol2026
# 2) Əvvəlcədən hash-lənmiş şifrə (production üçün tövsiyə olunur, bcrypt ilə yaradın)
# ADMIN_PASSWORD_HASH=$2b$10$...
